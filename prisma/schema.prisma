// Sapphire Vibes — luxury e-commerce data model.
// Money is stored as integer cents everywhere. IDs are cuid(). See plan §1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────── Enums ───────────────────────────────────────

enum Role {
  // customer-facing
  CUSTOMER
  INTERIOR_DESIGNER
  CORPORATE
  // staff (RBAC)
  SUPER_ADMIN
  ADMIN
  INVENTORY_MANAGER
  CATALOGUE_MANAGER
  CONTENT_EDITOR
  ORDER_FULFILMENT
  MARKETING_MANAGER
  FINANCE_MANAGER
  CUSTOMER_SUPPORT
}

enum CustomerType {
  RETAIL
  VIP
  TRADE
  CORPORATE
}

enum OrderStatus {
  PENDING
  PROCESSING
  PACKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  VISA
  MASTERCARD
  AMEX
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  AFTERPAY
  ZIP
  BANK_TRANSFER
  GIFT_CARD
  MOCK
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ProductBadge {
  LATEST
  HOT_SELLING
  BEST_SELLER
  PREMIUM
  LUXURY
  STAFF_PICK
  LIMITED
  GIFT_IDEA
  NEW_COLLECTION
  ECO
  AUSTRALIAN_MADE
  ON_SALE
  FESTIVAL
  CHRISTMAS
  VALENTINES
  MOTHERS_DAY
  FATHERS_DAY
  HALLOWEEN
  NEW_YEAR
  EASTER
}

enum CouponType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

enum PromotionType {
  FLASH_SALE
  BOGO
  BUNDLE
  SPEND_SAVE
  GIFT_WITH_PURCHASE
  MEMBER_EXCLUSIVE
  SEASONAL
  BIRTHDAY
}

enum PriceRuleScope {
  ALL
  CATEGORY
  COLLECTION
  BRAND
}

enum RewardReason {
  ORDER_EARN
  REDEEM
  SIGNUP
  FIRST_PURCHASE
  REVIEW
  REFERRAL
  BIRTHDAY
  PROFILE
  SOCIAL
  ADJUSTMENT
}

enum CollectionType {
  MANUAL
  AUTO
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  LIVE
  SENT
  PAUSED
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  VOID
}

enum ReferralStatus {
  INVITED
  JOINED
  CONVERTED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  FLAGGED
  REJECTED
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum IntegrationStatus {
  CONNECTED
  SETUP
  DISCONNECTED
}

enum AddressType {
  HOME
  WORK
  BILLING
  SHIPPING
  OTHER
}

// ─────────────────────────────────── Auth / identity ──────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  role         Role         @default(CUSTOMER)
  customerType CustomerType @default(RETAIL)

  vipTierId String?
  vipTier   VipTier? @relation(fields: [vipTierId], references: [id])

  pointsBalance    Int     @default(0)
  storeCreditCents Int     @default(0)
  phone            String?
  twoFactorEnabled Boolean @default(false)
  suspended        Boolean @default(false)
  permissions      Json?   // optional granular module allow-list (overrides role defaults)
  referralCode     String? @unique

  // notification preferences (account settings toggles)
  notifyOrderUpdates   Boolean @default(true)
  notifyNewCollections Boolean @default(true)
  notifySalesOffers    Boolean @default(false)
  notifyStyling        Boolean @default(true)

  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  orders             Order[]
  addresses          Address[]
  cart               CartItem[]
  wishlist           WishlistItem[]
  reviews            Review[]
  questions          ProductQuestion[]
  rewardTxns         RewardTransaction[]
  storeCreditTxns    StoreCreditTxn[]
  giftCardsPurchased GiftCard[]
  referralsMade      Referral[]          @relation("Referrer")
  referralsReceived  Referral[]          @relation("Referee")
  stockNotifications StockNotification[]
  auditLogs          AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────── Catalogue ─────────────────────────────────────

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  logoUrl  String?
  products Product[]
}

model Category {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String?
  imageUrl     String?
  displayOrder Int     @default(0)
  seoTitle     String?
  seoDesc      String?

  parentId String?
  parent   Category?  @relation("CatTree", fields: [parentId], references: [id])
  children Category[] @relation("CatTree")

  products Product[]
}

model Collection {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  heroImage   String?
  type        CollectionType @default(MANUAL)
  rulesJson   Json?
  isFeatured  Boolean        @default(false)
  displayOrder Int           @default(0)

  products Product[] @relation("ProductCollections")
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  sku              String        @unique
  barcode          String?
  description      String?       @db.Text
  careInstructions String?
  warranty         String?
  priceCents       Int
  compareCents     Int?
  costCents        Int?
  currency         String        @default("USD")
  taxClass         String        @default("GST 10%")
  status           ProductStatus @default(ACTIVE)
  badges           ProductBadge[]
  ratingAvg        Float         @default(0)
  ratingCount      Int           @default(0)
  salesCount       Int           @default(0)
  stock            Int           @default(0)
  minStockLevel    Int           @default(5)
  maxStock         Int           @default(100)
  weightGrams      Int?
  dimensions       String?
  material         String?
  colour           String?
  style            String?
  room             String?
  tags             String[]
  seoTitle         String?
  seoDescription   String?
  videoUrl         String?

  brandId    String?
  brand      Brand?    @relation(fields: [brandId], references: [id])
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  images             ProductImage[]
  collections        Collection[]        @relation("ProductCollections")
  looks              ShopTheLook[]       @relation("LookProducts")
  orderItems         OrderItem[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  reviews            Review[]
  questions          ProductQuestion[]
  stockNotifications StockNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  position   Int     @default(0)
  isFeatured Boolean @default(false)
}

model Supplier {
  id       String    @id @default(cuid())
  name     String    @unique
  contact  String?
  leadDays Int       @default(14)
  products Product[]
}

model ShopTheLook {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  heroImage String
  products  Product[] @relation("LookProducts")
}

// ───────────────────────────────────── Commerce ──────────────────────────────────────

model Address {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       AddressType @default(HOME)
  label      String?
  fullName   String
  line1      String
  line2      String?
  city       String
  region     String
  postalCode String
  country    String      @default("Australia")
  phone      String?
  isDefault  Boolean     @default(false)
  orders     Order[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model StockNotification {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([productId, email])
}

model Order {
  id            String        @id @default(cuid())
  number        String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  guestEmail    String?
  customerName  String
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod @default(MOCK)

  subtotalCents       Int
  discountCents       Int @default(0)
  shippingCents       Int @default(0)
  taxCents            Int @default(0)
  giftCardCents       Int @default(0)
  storeCreditCents    Int @default(0)
  pointsRedeemedCents Int @default(0)
  totalCents          Int

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  giftCardId String?
  giftCard   GiftCard? @relation(fields: [giftCardId], references: [id])

  shippingAddressId String?
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])
  shippingSnapshot  Json?
  shippingMethod    String?

  giftWrap       Boolean @default(false)
  giftMessage    String?
  orderNotes     String?
  trackingNumber String?
  carrier        String?

  items        OrderItem[]
  rewardTxns   RewardTransaction[]
  giftCardTxns GiftCardTxn[]
  referrals    Referral[]

  placedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([placedAt])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  nameSnapshot  String
  skuSnapshot   String
  imageSnapshot String?
  unitCents     Int
  quantity      Int
  lineCents     Int
}

// ─────────────────────────────────── Reviews & Q&A ───────────────────────────────────

model Review {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  authorName   String
  rating       Int
  title        String?
  body         String       @db.Text
  status       ReviewStatus @default(PUBLISHED)
  helpfulCount Int          @default(0)
  isFeatured   Boolean      @default(false)
  photos       ReviewPhoto[]
  createdAt    DateTime     @default(now())

  @@index([productId])
  @@index([status])
}

model ReviewPhoto {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String
}

model ProductQuestion {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  authorName String
  body      String
  answer    String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
}

// ────────────────────────────── Loyalty / rewards / VIP ──────────────────────────────

model RewardTransaction {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?       @relation(fields: [orderId], references: [id])
  points    Int
  reason    RewardReason
  note      String?
  createdAt DateTime     @default(now())

  @@index([userId])
}

model LoyaltyEarnRule {
  id     String @id @default(cuid())
  action String
  points String // e.g. "1 pt", "2× pts", "250 pts"
  order  Int    @default(0)
}

model LoyaltyRedeemOption {
  id         String @id @default(cuid())
  label      String
  pointsCost String // e.g. "500 pts", "VIP"
  valueCents Int?
  order      Int    @default(0)
}

model VipTier {
  id           String @id @default(cuid())
  name         String @unique // Silver / Gold / Elite
  blurb        String
  minSpendCents Int   @default(0)
  multiplier   Float  @default(1)
  benefits     String[]
  order        Int    @default(0)
  users        User[]
}

// ─────────────────────────────────── Gift & referral ─────────────────────────────────

model GiftCard {
  id            String         @id @default(cuid())
  code          String         @unique
  design        String         @default("Classic Gold")
  initialCents  Int
  balanceCents  Int
  status        GiftCardStatus @default(ACTIVE)
  purchaserId   String?
  purchaser     User?          @relation(fields: [purchaserId], references: [id])
  recipientEmail String?
  message       String?
  deliverAt     DateTime?
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())

  txns   GiftCardTxn[]
  orders Order[]
}

model GiftCardTxn {
  id         String   @id @default(cuid())
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id])
  deltaCents Int
  createdAt  DateTime @default(now())
}

model Referral {
  id            String         @id @default(cuid())
  referrerId    String
  referrer      User           @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  code          String
  refereeEmail  String?
  refereeUserId String?
  refereeUser   User?          @relation("Referee", fields: [refereeUserId], references: [id])
  status        ReferralStatus @default(INVITED)
  rewardCents   Int            @default(2000)
  orderId       String?
  order         Order?         @relation(fields: [orderId], references: [id])
  createdAt     DateTime       @default(now())

  @@index([referrerId])
}

model StoreCreditTxn {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deltaCents Int
  reason     String
  refId      String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ───────────────────────────────── Promotions & pricing ──────────────────────────────

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  percent        Int?
  valueCents     Int?
  description    String?
  minSubtotal    Int?
  firstOrderOnly Boolean    @default(false)
  tradeOnly      Boolean    @default(false)
  isActive       Boolean    @default(true)
  usageLimit     Int?
  usedCount      Int        @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())

  orders Order[]
}

model Promotion {
  id          String        @id @default(cuid())
  name        String
  type        PromotionType
  discount    String // display label, e.g. "−20%", "3 for 2"
  config      Json?
  audience    String        @default("All customers")
  channel     String?
  startsAt    DateTime?
  endsAt      DateTime?
  status      CampaignStatus @default(LIVE)
  redemptions Int           @default(0)
  createdAt   DateTime      @default(now())
}

model PriceRule {
  id             String         @id @default(cuid())
  name           String
  scope          PriceRuleScope @default(ALL)
  targetId       String?
  targetLabel    String?
  adjustmentType String // "decrease_pct" | "increase_pct" | "set_fixed"
  value          Int
  status         CampaignStatus @default(LIVE)
  scheduleAt     DateTime?
  createdAt      DateTime       @default(now())
}

// ───────────────────────────────────── Marketing / CRM ───────────────────────────────

model EmailCampaign {
  id         String         @id @default(cuid())
  name       String
  channel    String         @default("Email")
  status     CampaignStatus @default(SENT)
  openRate   Float?
  clickRate  Float?
  audience   String?
  sentAt     DateTime?
  scheduleAt DateTime?
  createdAt  DateTime       @default(now())
}

model EmailAutomation {
  id         String         @id @default(cuid())
  name       String
  trigger    String
  status     CampaignStatus @default(LIVE)
  metric     String?
  createdAt  DateTime       @default(now())
}

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  status      String   @default("Subscribed")
  doubleOptIn Boolean  @default(true)
  segments    String[]
  createdAt   DateTime @default(now())
}

model Segment {
  id          String   @id @default(cuid())
  name        String   @unique
  rule        String
  count       Int      @default(0)
  avgClvCents Int      @default(0)
  consent     String   @default("Opted in")
}

model Integration {
  id        String            @id @default(cuid())
  name      String            @unique
  category  String
  blurb     String?
  status    IntegrationStatus @default(SETUP)
}

// ───────────────────────────────────── CMS / content ─────────────────────────────────

model HomepageBlock {
  id         String        @id @default(cuid())
  key        String        @unique
  name       String
  type       String
  blurb      String?
  config     Json?
  position   Int           @default(0)
  isVisible  Boolean       @default(true)
  scheduleAt DateTime?
}

model Page {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  body      String        @db.Text
  status    ContentStatus @default(PUBLISHED)
  seoTitle  String?
  seoDesc   String?
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
}

model BlogPost {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  category    String
  excerpt     String?
  body        String        @db.Text
  coverUrl    String?
  status      ContentStatus @default(PUBLISHED)
  views       Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  // { author, tags[], featured, pinned, allowComments, readingTime, gallery[], scheduledAt }
  meta        Json?
  comments    BlogComment[]
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String
  email     String?
  body      String   @db.Text
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt DateTime @default(now())

  @@index([postId])
}

model Faq {
  id       String @id @default(cuid())
  question String
  answer   String @db.Text
  category String @default("General")
  position Int    @default(0)
}

model Testimonial {
  id         String  @id @default(cuid())
  quote      String  @db.Text
  author     String
  location   String?
  rating     Int     @default(5)
  isFeatured Boolean @default(true)
}

// ────────────────────────────────────── System ───────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  actorName  String?
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model Redirect {
  id        String   @id @default(cuid())
  from      String   @unique
  to        String
  permanent Boolean  @default(true) // 301 (permanent) vs 302 (temporary)
  hits      Int      @default(0)
  createdAt DateTime @default(now())
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  type      String   @default("image/jpeg")
  alt       String?
  folder    String   @default("general")
  tags      String[] @default([])
  bytes     Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([folder])
}
