# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Local dev: a local Postgres instance. Production: your Hostinger VPS Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sapphire?schema=public"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth client ID)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
