# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Local dev: a local Postgres instance. Production: your Hostinger VPS Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sapphire?schema=public"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth client ID)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── CMS / enterprise features (all optional) ────────────────────────────
# Canonical public URL — powers sitemap.xml, robots.txt, OG tags and redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# AI content assistant (blog drafts + SEO meta). Leave blank to disable the AI buttons.
ANTHROPIC_API_KEY=""

# Secret guarding the scheduled-publishing cron (/api/cron/publish?secret=…).
CRON_SECRET=""
